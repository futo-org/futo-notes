# Deny all by default
*

# Whitelist workspace manifests
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!.npmrc

# Whitelist server app
!apps/server/
apps/server/dist/
apps/server/node_modules/
apps/server/data/
apps/server/.env

# Whitelist shared package
!packages/shared/
packages/shared/node_modules/
