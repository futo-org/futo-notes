{
  "name": "futo-notes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "lint:platform": "! grep -rn 'platform/electron\\|platform/capacitor' src/lib/ --include='*.ts' | grep -v 'platform/' | grep -v '__mocks__' | grep -v '.test.ts'",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "mobile:sync": "npm run build && cd apps/mobile && npx cap sync",
    "mobile:run:android": "npm run build && cd apps/mobile && npx cap sync android && npx cap run android",
    "mobile:run:ios": "npm run build && cd apps/mobile && npx cap sync ios && npx cap run ios",
    "mobile:open:android": "cd apps/mobile && npx cap open android",
    "mobile:open:ios": "cd apps/mobile && npx cap open ios",
    "desktop:dev": "cd apps/desktop && npm run dev",
    "desktop:build": "npm run build && cd apps/desktop && npm run build",
    "desktop:package:linux": "npm run build && cd apps/desktop && npm run package:linux",
    "server:dev": "cd apps/server && npm run dev",
    "server:test": "cd apps/server && npm test"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language-data": "6.5.2",
    "@lucide/svelte": "^0.574.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "codemirror": "6.0.2",
    "@xenova/transformers": "^2.17.0",
    "minisearch": "7.2.0",
    "svelte": "^5.49.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "7.3.1",
    "vitest": "^4.0.18"
  }
}
