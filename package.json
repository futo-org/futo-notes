{
  "name": "futo-notes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "devalue@<5.8.1": "5.8.1",
      "picomatch@4": "4.0.4",
      "esbuild@<0.28.1": "0.28.1"
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src packages/shared/src packages/editor/src --ext .ts",
    "lint:platform": "! git grep -n -E \"platform/(electron|capacitor)|isElectron|isCapacitor\" -- src ':(exclude)src/lib/platform/**' ':(exclude)src/**/__mocks__/**' ':(exclude)src/**/*.test.ts'",
    "test": "pnpm run test:minimal",
    "test:minimal": "pnpm exec tsx tests/conformance/generate.mjs --check && pnpm run test:unit:minimal && pnpm run test:shared:minimal && pnpm run test:editor:minimal",
    "test:full": "pnpm run test:unit:full && pnpm run test:shared:full && pnpm run test:editor:full",
    "test:e2e:smoke": "playwright test tests/p0-regressions.spec.ts",
    "test:e2e:full": "playwright test",
    "test:markdown-spec": "playwright test tests/markdown-spec.spec.ts",
    "test:e2e:rest": "playwright test --grep-invert \"Markdown Spec\"",
    "test:unit": "pnpm run test:unit:minimal",
    "test:unit:minimal": "vitest run src/lib/editorInit.test.ts src/lib/platform/pathSafety.test.ts src/lib/platform/tauriPaths.test.ts src/lib/platform/windowsRuntimeConfig.test.ts src/lib/updater.test.ts src/lib/updateChecker.svelte.test.ts src/lib/platform/updaterConfig.test.ts src/components/UpdateBanner.svelte.test.ts scripts/build-updater-manifest.test.mjs scripts/desktop-version.test.mjs scripts/release-build.test.mjs scripts/release-channel.test.mjs scripts/verify-updater-signature.test.mjs scripts/tauri-test-client.test.mjs",
    "test:unit:full": "vitest run",
    "test:shared": "pnpm run test:shared:minimal",
    "test:shared:minimal": "pnpm --filter @futo-notes/shared exec vitest run src/image.test.ts",
    "test:shared:full": "pnpm --filter @futo-notes/shared test",
    "test:editor": "pnpm run test:editor:minimal",
    "test:editor:minimal": "pnpm --filter @futo-notes/editor exec vitest run src/conformance.test.ts src/bridge.test.ts",
    "test:editor:full": "pnpm --filter @futo-notes/editor test",
    "test:all": "pnpm run test:minimal",
    "test:unit:watch": "vitest",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "ci": "pnpm run lint && pnpm run test:minimal && pnpm run build",
    "_comment": "Tauri commands (dev, build, deploy) live in the justfile — use `just` from the monorepo root. Only toolchain scripts (vite, vitest, playwright, eslint) belong here.",
    "test:desktop-smoke": "node tests/desktop-smoke.mjs",
    "test:cross-platform": "node tests/cross-platform-sync.mjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.2",
    "@codemirror/language-data": "6.5.2",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@lezer/common": "1.5.1",
    "@lezer/highlight": "1.2.3",
    "@lucide/svelte": "^0.574.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "codemirror": "6.0.2",
    "minisearch": "7.2.0",
    "svelte": "^5.49.2",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@types/js-yaml": "^4.0.9",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "eslint": "^10.1.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.1.0",
    "pixelmatch": "^7.1.1",
    "pngjs": "^7.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "7.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.0.18",
    "ws": "^8.20.0"
  }
}
