{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://futo-notes.local/experiments/entity-lab/entity-extraction.schema.json",
  "title": "EntityExtraction",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "entities"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "entities": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name", "aliases", "confidence", "evidence"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["project", "person", "organization", "tool", "place"]
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "aliases": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          }
        }
      }
    }
  }
}
