# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/
Pods/

# Build output
dist/
.sourcemaps

# Capacitor generated assets (regenerated on cap sync)
android/app/src/main/assets/public/*
!android/app/src/main/assets/public/.gitkeep
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
ios/App/App/public/*
!ios/App/App/public/.gitkeep

# Android
.gradle/
.kotlin/
local.properties
*.iml
.settings/
.project

# iOS
xcuserdata/
Podfile.lock
Build/*
Index/
DerivedData/

# Native signing
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
release.keystore

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*
capacitor-build.log

# macOS
.DS_Store
*.pem

# Environment files
.env
.env*.local

# TypeScript
*.tsbuildinfo

# IDE
.vscode
.idea/
.*sw*

app-example

# Capacitor platform folders (tracked for CI/CD)
# /ios
# /android
