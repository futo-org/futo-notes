# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Dependencies
node_modules/
Pods/

# Build output
dist/
.sourcemaps

# Capacitor generated assets (regenerated on cap sync)
apps/mobile/android/app/src/main/assets/public/*
!apps/mobile/android/app/src/main/assets/public/.gitkeep
apps/mobile/android/app/src/main/assets/capacitor.config.json
apps/mobile/android/app/src/main/assets/capacitor.plugins.json
apps/mobile/ios/App/App/public/*
!apps/mobile/ios/App/App/public/.gitkeep

# Android
.gradle/
.kotlin/
local.properties
*.iml
.settings/
.project

# iOS
xcuserdata/
Podfile.lock
Build/
build/
Index/
DerivedData/
apps/mobile/ios/build/

# Native signing
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
release.keystore

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*
capacitor-build.log

# macOS
.DS_Store
*.pem

# Environment files
.env
.env*.local

# TypeScript
*.tsbuildinfo

# IDE
.vscode
.idea/
.*sw*

app-example

# Desktop (Electron)
apps/desktop/dist-electron/
apps/desktop/release/

# Server
apps/server/dist/

# Playwright
.playwright-mcp
test-results/

# Claude
.claude/local-plugins/*
