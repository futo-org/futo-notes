# FUTO Notes — environment reference
#
# These are SHELL environment variables, not auto-loaded by the app. The skills
# and test recipes expect them in your shell (they run `source ~/.zshrc`). Add
# the ones you need to your shell profile (~/.zshrc, ~/.bashrc), or copy this
# file to `.env` (gitignored) and `source .env` before running those commands.
#
# None of these are required just to build/run the app locally — they gate
# specific workflows (release tooling, Zulip, sync tests, mobile builds).

# GitLab API token (scope: read_api). Used by the /release, /verify, and /zulip
# skills and the CI-status snippets in AGENTS.md. Create at:
#   https://gitlab.futo.org/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Zulip API key for https://zulip.futo.org, used by the /zulip skill.
# Get it from Zulip → Settings → Account & privacy → API key.
# NOTE: the /zulip skill currently hardcodes justin@futo.org as the auth email —
# swap in your own address when you use it.
ZULIP_API_KEY=

# Path to the external E2EE sync server checkout (separate repo:
# https://gitlab.futo.org/futo-notes/futo-notes-server). Needed for the
# cross-platform and mac-ios sync test suites. Defaults to the path below if unset.
FUTO_NOTES_E2EE_SERVER_REPO=$HOME/Developer/futo-notes-server

# Apple Developer Team ID — only for native iOS builds onto a physical device
# (`just ios-native-device`). Defaults to the Tauri app's dev team if unset.
FUTO_DEV_TEAM=

# Android native builds (`just android-native` / build-rust-android) need the
# SDK + NDK. Point these at your installs.
ANDROID_HOME=$HOME/Android/Sdk
ANDROID_NDK_HOME=$HOME/Android/Sdk/ndk/<version>
