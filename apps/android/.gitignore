# Gradle / build outputs
.gradle/
build/
local.properties
*.iml

# Signing secrets — NEVER commit. build.gradle.kts reads keystore.properties
# for the release signingConfig; the upload keystore itself stays out of git.
keystore.properties
*.jks
*.keystore
# Google Play service-account JSON (CI supplies it via ANDROID_PUBLISHER_CREDENTIALS).
play-service-account.json

