<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sync talks to the E2EE server over HTTP(S). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- DEVICE storage mode [app.md]: keeps the vault in a shared folder
         (Documents/FUTO Notes) the user can open in the Files app + sync with
         other apps. The Rust core does direct std::fs path I/O, so SAF/content
         URIs are not viable; broad access is the only way to a user-visible,
         path-addressable vault (same reason Obsidian declares this). It is a
         user-granted "All files access" special permission (Settings), never an
         install-time grant; APP storage is the no-permission alternative. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Cleartext HTTP is permitted in all build types (usesCleartextTraffic
         below) so self-hosters and testers can point at a plain-http:// server
         (a LAN box or a VPS without TLS). Note content is E2EE-encrypted
         client-side before upload, so the transport carries only opaque blobs +
         auth. HTTPS is still recommended; this only removes the OS-level block
         on http://. -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${appLabel}"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Camera capture target for the editor's pickImage flow: TakePicture
             writes into a cache file exposed via this provider. No CAMERA
             permission needed — the system camera app does the capturing. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
