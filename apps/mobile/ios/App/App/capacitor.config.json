{
	"appId": "com.futo.notes",
	"appName": "Stonefruit",
	"webDir": "../../dist",
	"server": {
		"androidScheme": "http"
	},
	"android": {
		"useSafeArea": false
	},
	"ios": {
		"contentInset": "never",
		"scrollEnabled": false
	},
	"plugins": {
		"Keyboard": {
			"resize": "none",
			"resizeOnFullScreen": false
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPCameraPlugin",
		"FilesystemPlugin",
		"HapticsPlugin",
		"KeyboardPlugin",
		"StatusBarPlugin"
	]
}
