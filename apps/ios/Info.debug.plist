<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- DEBUG-ONLY base Info.plist. Wired via project.yml's Debug config
	     (INFOPLIST_FILE). With GENERATE_INFOPLIST_FILE=YES, Xcode merges the
	     auto-generated keys (display name, scene/launch, orientations) ON TOP of
	     this file, so the ONLY thing this contributes is the App Transport
	     Security exception below. Release sets no INFOPLIST_FILE and ships NO ATS
	     exception — it behaves byte-identically to before the dev/prod split
	     (F10). The flat INFOPLIST_KEY_NSAppTransportSecurity_* build-setting form
	     does NOT synthesize this nested dict (Xcode only honors a fixed allowlist
	     of INFOPLIST_KEY_* names), which is why this file exists. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allows the dev sync server over plain http on localhost / LAN. -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
