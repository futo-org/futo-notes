{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FUTO Notes",
  "version": "0.1.0",
  "identifier": "com.futo.notes.tauri",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../..",
    "beforeBuildCommand": "npm run build --prefix ../..",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "FUTO Notes",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon-1024-rgba8.png"
    ]
  }
}
