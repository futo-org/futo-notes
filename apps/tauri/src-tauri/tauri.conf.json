{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FUTO Notes",
  "version": "0.1.0",
  "identifier": "com.futo.notes",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. run dev --host 127.0.0.1 --port 5180 --strictPort",
    "beforeBuildCommand": "pnpm --dir ../.. run build",
    "devUrl": "http://127.0.0.1:5180",
    "frontendDist": "../../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FUTO Notes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 20 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: http: data:; font-src 'self' data:; connect-src 'self' https: http: ws: wss:; media-src 'self' asset:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "/tmp/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NTVGMDk4QkM5QzQ5RjMKUldUelNaeThtUEJWV2FhQ3FVSDVZcU1zdmgwSnY0b1NUdHIyWWgzUUV4amIrSzNpc1UwMkduRWoK",
      "endpoints": [
        "https://gitlab.futo.org/futo-notes/futo-notes/-/releases/permalink/latest/downloads/latest.json"
      ]
    }
  }
}
