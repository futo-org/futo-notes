{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FUTO Notes",
  "version": "0.1.0",
  "identifier": "com.futo.notes",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../.. -- --host 127.0.0.1 --port 5180 --strictPort",
    "beforeBuildCommand": "npm run build --prefix ../..",
    "devUrl": "http://127.0.0.1:5180",
    "frontendDist": "../../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FUTO Notes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 19, "y": 14 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: http: data:; font-src 'self' data:; connect-src 'self' https: http: ws: wss:; media-src 'self' asset:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**", "/tmp/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/futo-notes/libonnxruntime.so": "gen/linux/libonnxruntime.so"
        }
      },
      "rpm": {
        "files": {
          "/usr/lib/futo-notes/libonnxruntime.so": "gen/linux/libonnxruntime.so"
        }
      },
      "appimage": {
        "files": {
          "usr/bin/libonnxruntime.so": "gen/linux/libonnxruntime.so"
        }
      }
    },
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
