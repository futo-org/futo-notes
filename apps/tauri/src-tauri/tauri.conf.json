{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stonefruit",
  "version": "0.1.0",
  "identifier": "com.futo.notes.tauri",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../.. -- --host 127.0.0.1 --port 5180 --strictPort",
    "beforeBuildCommand": "npm run build --prefix ../..",
    "devUrl": "http://127.0.0.1:5180",
    "frontendDist": "../../../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Stonefruit",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon-1024-rgba8.png"
    ]
  }
}
