{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "dialog:allow-save",
    "dialog:allow-open",
    "process:allow-restart",
    "process:allow-exit",
    "clipboard-manager:allow-write-text",
    "opener:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-decorations",
    "mcp-bridge:default",
    "fs:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-read-file", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-remove", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-mkdir", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-rename", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "**" }, { "path": "**/*" }] },
    { "identifier": "fs:allow-stat", "allow": [{ "path": "**" }, { "path": "**/*" }] }
  ]
}
